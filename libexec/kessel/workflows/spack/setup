#!/bin/bash
#KESSEL title: Setup
#KESSEL collapsed: true

export KESSEL_SYSTEM="${KESSEL_SYSTEM:-local}"
export KESSEL_WORKFLOW_DEPLOYMENT="${KESSEL_WORKFLOW_DEPLOYMENT:-${TMPDIR:-/tmp}/$USER-ci-envs}"

TEMP=()
while (( "$#" )); do
  case "$1" in
    -h|--help)
      usage
      return
      ;;
    -D|--deployment)
      if [ -n "$2" ] && [[ "$2" != -* ]]; then
         export KESSEL_WORKFLOW_DEPLOYMENT="$2"
         shift 2
      else
         echo "ERROR: -I/--install-dir requires an argument." >&2
         false
         return
      fi
      ;;
    --deployment=*)
      value="${1#*=}"
      export KESSEL_WORKFLOW_DEPLOYMENT="$value"
      shift
      ;;
    -s|--system)
      if [ -n "$2" ] && [[ "$2" != -* ]]; then
         export KESSEL_SYSTEM="$2"
         shift 2
      else
         echo "ERROR: -s/--system requires an argument." >&2
         false
         return
      fi
      ;;
    --system=*)
      value="${1#*=}"
      export KESSEL_SYSTEM="$value"
      shift
      ;;
    -*|--*)
      echo "ERROR: invalid option $1" >&2
      false
      return
      ;;
    *)
      TEMP+=("$1")
      shift
      ;;
  esac
done

umask 0007
if [[ "$KESSEL_SYSTEM" == "local" ]]; then
  if [[ -z "$SPACK_ROOT" ]]; then
    echo "ERROR: No active Spack installation!" >&2
    false
    return
  else
    echo "Using Spack install at $SPACK_ROOT"
  fi
else
  if [ ! -d "$KESSEL_WORKFLOW_DEPLOYMENT" ]; then
      unsquashfs -d "$KESSEL_WORKFLOW_DEPLOYMENT" "$KESSEL_DEPLOYMENT/.replicate.sqfs"
      kessel deploy activate "$KESSEL_WORKFLOW_DEPLOYMENT"
      kessel system activate "$KESSEL_SYSTEM"
  fi
fi
