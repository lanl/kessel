#!/bin/bash
#KESSEL title: Setup
#KESSEL collapsed: true

export KESSEL_SOURCE_DIR="${KESSEL_SOURCE_DIR:-$PWD}"
export KESSEL_BUILD_DIR="${KESSEL_BUILD_DIR:-$PWD/build}"
export KESSEL_ENVIRONMENT="${KESSEL_ENVIRONMENT:-default}"
export KESSEL_REQUIREMENTS="${KESSEL_REQUIREMENTS:-requirements.txt}"

TEMP=()
while (( "$#" )); do
  case "$1" in
    -h|--help)
      usage
      return
      ;;
    -S|--source-dir)
      if [ -n "$2" ] && [[ "$2" != -* ]]; then
         export KESSEL_SOURCE_DIR="$2"
         shift 2
      else
         echo "ERROR: -S/--source-dir requires an argument." >&2
         false
         return
      fi
      ;;
    -B|--build-dir)
      if [ -n "$2" ] && [[ "$2" != -* ]]; then
         export KESSEL_BUILD_DIR="$2"
         shift 2
      else
         echo "ERROR: -B/--build-dir requires an argument." >&2
         false
         return
      fi
      ;;
    -e|--env)
      if [ -n "$2" ] && [[ "$2" != -* ]]; then
         export KESSEL_ENVIRONMENT="$2"
         shift 2
      else
         echo "ERROR: -e/--env requires an argument." >&2
         false
         return
      fi
      ;;
    --source-dir=*)
      value="${1#*=}"
      export KESSEL_SOURCE_DIR="$value"
      shift
      ;;
    --build-dir=*)
      value="${1#*=}"
      export KESSEL_BUILD_DIR="$value"
      shift
      ;;
    --env=*)
      value="${1#*=}"
      export KESSEL_ENVIRONMENT="$value"
      shift
      ;;
    -*|--*)
      echo "ERROR: invalid option $1" >&2
      false
      return
      ;;
    *)
      TEMP+=("$1")
      shift
      ;;
  esac
done

ENV_DIR="$KESSEL_BUILD_DIR/envs"
ENV="$ENV_DIR/$KESSEL_ENVIRONMENT"
mkdir -p "$ENV_DIR"

if [ ! -d "$ENV" ]; then
    "$KESSEL_PYTHON" -m venv "$ENV"
fi

source "$ENV/bin/activate"

if [ $? -ne 0 ]; then
    echo "Failed to activate environment"
    false
    return
fi

python3 -m pip install -r "$KESSEL_REQUIREMENTS"
deactivate

export KESSEL_BUILD_ENV=${ENV}/bin/activate
