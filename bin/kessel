#!/bin/sh
""":"
PREFERRED_PYTHONS="python3.13 python3.12 python3.11 python3.8 python3"
for cmd in $PREFERRED_PYTHONS; do
    if command -v > /dev/null "$cmd"; then
        export KESSEL_PYTHON="$(command -v "$cmd")"
        exec "${KESSEL_PYTHON}" "$0" "$@"
    fi
done

echo "Could not find python interpreter" >&2
exit 1
":"""

import os
import sys

kessel_file = os.path.realpath(__file__)
kessel_root = os.path.dirname(os.path.dirname(kessel_file))

kessel_lib_path = os.path.join(kessel_root, "lib")
vendored_libs_path = os.path.join(kessel_root, "lib", "kessel", "external", "_vendoring")
sys.path.insert(0, vendored_libs_path)
sys.path.insert(0, kessel_lib_path)

from kessel.main import main

if __name__ == "__main__":
    sys.exit(main())
