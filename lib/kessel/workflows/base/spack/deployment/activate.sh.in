export KESSEL_DEPLOYMENT="$( cd "$( dirname "${BASH_SOURCE[0]:-$0}" )" >/dev/null 2>&1 && pwd )"
export KESSEL_PARENT_DEPLOYMENT="@KESSEL_PARENT_DEPLOYMENT@"
export KESSEL_SYSTEM="@KESSEL_SYSTEM@"

source "$KESSEL_DEPLOYMENT/kessel/share/kessel/setup-env.sh"
export KESSEL_CONFIG_DIR="$KESSEL_ROOT/etc/kessel/spack-deployment"

source "$KESSEL_ROOT/lib/kessel/workflows/base/spack/deployment/activate.sh"
